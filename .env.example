CLAN_NAME=MiClan
TURSO_URL=libsql://tu-db.turso.io
TURSO_AUTH_TOKEN=tu-token

# Discord Webhooks — Ajustes del canal → Integraciones → Webhooks → Crear
DISCORD_WEBHOOK_EVENTOS=    # Canal #eventos    — sorteo diario 03:00 UTC
DISCORD_WEBHOOK_BOSSES=     # Canal #boss-report — resumen 23:55 UTC
DISCORD_WEBHOOK_QUESTS=     # Canal #misiones   — quests 23:50 UTC
DISCORD_WEBHOOK_RANKING=    # Canal #ranking      — top semanal 23:59 UTC
DISCORD_WEBHOOK_INACTIVIDAD= # Canal #inactividad — reporte 12:00 UTC

# Discord Roles — ID del rol a mencionar por canal (opcional)
# Para obtener el ID: Discord → Ajustes servidor → Roles → clic derecho → Copiar ID
DISCORD_ROLE_EVENTOS=        # Rol que se menciona en el anuncio del evento diario
DISCORD_ROLE_BOSSES=         # Rol que se menciona en el boss report
DISCORD_ROLE_INACTIVIDAD=    # Rol de moderador/líder para el reporte de inactivos
DISCORD_ROLE_LOGROS=         # Rol que se menciona cuando alguien sube de nivel
